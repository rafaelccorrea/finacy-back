# ============================================================
# FINACY BACK - Variáveis de Ambiente (Vercel)
# Copie este arquivo e preencha os valores no dashboard da Vercel
# Settings > Environment Variables
# ============================================================

# Application
NODE_ENV=production
PORT=3001
APP_NAME=Finacy API
APP_URL=https://seu-projeto.vercel.app
FRONTEND_URL=https://seu-frontend.vercel.app

# Database (Supabase PostgreSQL - use Connection Pooler)
DB_HOST=seu-host.pooler.supabase.com
DB_PORT=5432
DB_USERNAME=postgres.xxx
DB_PASSWORD=sua_senha
DB_NAME=postgres
DB_SSL=true
DATABASE_URL=postgresql://usuario:senha@host:5432/postgres

# JWT Authentication
JWT_SECRET=chave_minima_32_caracteres_producao
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=chave_refresh_minima_32_caracteres
JWT_REFRESH_EXPIRES_IN=30d

# Stripe Payment
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# Autentique (Document Signing)
AUTENTIQUE_API_KEY=sua_api_key
AUTENTIQUE_API_URL=https://api.autentique.com.br/v2

# AWS S3
AWS_REGION=us-east-1
AWS_S3_BUCKET=seu-bucket
AWS_ACCESS_KEY_ID=sua_access_key
AWS_SECRET_ACCESS_KEY=sua_secret_key

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS (URLs do frontend separadas por vírgula)
# Exemplo: https://grey-penguin-269757.hostingersite.com,https://meudominio.com
CORS_ORIGINS=https://grey-penguin-269757.hostingersite.com

# Bcrypt
BCRYPT_ROUNDS=12

# Encryption
ENCRYPTION_KEY=chave_32_caracteres_producao
