# Application
NODE_ENV=development
PORT=3001
APP_NAME=Finacy API
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=finacy_user
DB_PASSWORD=your_secure_password
DB_NAME=finacy_db
DB_SSL=false

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_minimum_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# AWS S3 (Document Storage)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=finacy-documents

# Autentique (Document Signing)
AUTENTIQUE_API_KEY=your_autentique_api_key
AUTENTIQUE_API_URL=https://api.autentique.com.br/v2

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Bcrypt
BCRYPT_ROUNDS=12

# Encryption
ENCRYPTION_KEY=your_32_char_encryption_key_here_
